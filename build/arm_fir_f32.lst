 145:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****   @addtogroup FIR
 146:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****   @{
 147:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****  */
 148:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** 
 149:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** /**
 150:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****   @brief         Processing function for floating-point FIR filter.
 151:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****   @param[in]     S          points to an instance of the floating-point FIR filter structure
 152:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****   @param[in]     pSrc       points to the block of input data
 153:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****   @param[out]    pDst       points to the block of output data
 154:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****   @param[in]     blockSize  number of samples to process
 155:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****  */
 156:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** 
 157:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** #if defined(ARM_MATH_MVEF) && !defined(ARM_MATH_AUTOVECTORIZE)
 158:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** 
 159:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** #define FIR_F32_MAX_COEF_BLK        8
 160:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** 
 161:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** #define FIR_F32_CORE(pSamples, c, NB_TAPS)                                 \
 162:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****         vecAcc0 = vdupq_n_f32(0.0f);                                       \
 163:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****         for (int i = 0; i < NB_TAPS; i++) {                                \
 164:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****             vecIn0 = vld1q(&pSamples[i]);                                  \
 165:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****             vecAcc0 = vfmaq(vecAcc0, vecIn0, c[i]);                        \
 166:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****         }
 167:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** 
 168:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** 
 169:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** #define NB_TAPS 4
 170:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** __STATIC_INLINE void arm_fir_f32_1_4_mve(const arm_fir_instance_f32 * S, 
 171:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****   const float32_t * __restrict pSrc, 
 172:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****   float32_t * __restrict pDst, uint32_t blockSize)
 173:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c **** {
 174:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     float32_t *pRefStatePtr = S->pState + blockSize;
 175:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     float32_t      *pState = pRefStatePtr; /* State pointer */
 176:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     const float32_t *pCoeffs = S->pCoeffs;      /* Coefficient pointer */
 177:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     float32_t      *pStateCur;  /* Points to the current sample of the state */
 178:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     const float32_t *pSamples;  /* Temporary pointer to the sample buffer */
 179:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     float32_t      *pOutput;    /* Temporary pointer to the output buffer */
 180:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     const float32_t *pTempSrc;  /* Temporary pointer to the source data */
 181:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     float32_t      *pTempDest;  /* Temporary pointer to the destination buffer */
 182:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     uint32_t        numTaps = S->numTaps;       /* Number of filter coefficients in the filter */
 183:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     int32_t         blkCnt;
 184:Drivers/CMSIS_DSP/Source/FilteringFunctions/arm_fir_f32.c ****     float32x4_t         vecIn0;
