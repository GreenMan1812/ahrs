 139:Middlewares/Third_Party/FreeRTOS/Source/CMSIS_RTOS_V2/cmsis_os2.c ****   #define HEAP_5_REGION_SETUP   0
 140:Middlewares/Third_Party/FreeRTOS/Source/CMSIS_RTOS_V2/cmsis_os2.c **** #endif /* configAPPLICATION_ALLOCATED_HEAP */
