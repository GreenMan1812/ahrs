 747:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                        break;
 748:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                      case 512:
 749:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                        S = &arm_cfft_sR_f32_len512;
 750:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                        break;
 751:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                      case 1024:
 752:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                        S = &arm_cfft_sR_f32_len1024;
 753:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                        break;
 754:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                      case 2048:
 755:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                        S = &arm_cfft_sR_f32_len2048;
 756:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                        break;
 757:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                      case 4096:
 758:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                        S = &arm_cfft_sR_f32_len4096;
 759:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                        break;
 760:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****                    }
 761:Drivers/CMSIS_DSP/Source/TransformFunctions/arm_cfft_f32.c ****   @endcode
