 131:AHRS_Lib/ahrs.c **** uint8_t get_component(int8_t idx, int8_t comp_idx)
 132:AHRS_Lib/ahrs.c **** {
 133:AHRS_Lib/ahrs.c ****     if(idx < 3){
 134:AHRS_Lib/ahrs.c ****         return _neighbor_umbrellas[idx].components[comp_idx];
 135:AHRS_Lib/ahrs.c ****     }
 136:AHRS_Lib/ahrs.c ****     return (_neighbor_umbrellas[idx % 3].components[comp_idx] + 10) % 20;
 137:AHRS_Lib/ahrs.c **** }
