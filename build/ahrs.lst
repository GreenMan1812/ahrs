 146:AHRS_Lib/ahrs.c **** int8_t AHRS_SectionGrid(float* vec)
 147:AHRS_Lib/ahrs.c **** {
 148:AHRS_Lib/ahrs.c ****     int8_t i = _grid_index(vec);
 149:AHRS_Lib/ahrs.c ****     if(i == -1) return -1;
 150:AHRS_Lib/ahrs.c ****     int8_t j = _sub_grid_index(vec, i);
 151:AHRS_Lib/ahrs.c ****     if(j == -1) return -1;
 152:AHRS_Lib/ahrs.c ****     return i * 4 + j;
 153:AHRS_Lib/ahrs.c **** }
