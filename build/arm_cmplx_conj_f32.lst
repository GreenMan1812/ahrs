  74:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** 
  75:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** ARM_DSP_ATTRIBUTE void arm_cmplx_conj_f32(
  76:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     const float32_t * pSrc,
  77:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     float32_t * pDst,
  78:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     uint32_t numSamples)
  79:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** {
  80:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     static const float32_t cmplx_conj_sign[4] = { 1.0f, -1.0f, 1.0f, -1.0f };
  81:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     uint32_t blockSize = numSamples * CMPLX_DIM;   /* loop counters */
  82:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     uint32_t blkCnt;
  83:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     f32x4_t vecSrc;
  84:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     f32x4_t vecSign;
  85:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** 
  86:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     /*
  87:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****      * load sign vector
ARM GAS  /tmp/ccJ9AIul.s 			page 3


  88:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****      */
  89:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     vecSign = *(f32x4_t *) cmplx_conj_sign;
  90:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** 
  91:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     /* Compute 4 real samples at a time */
  92:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     blkCnt = blockSize >> 2U;
  93:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** 
  94:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     while (blkCnt > 0U)
  95:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     {
  96:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****         vecSrc = vld1q(pSrc);
  97:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****         vst1q(pDst,vmulq(vecSrc, vecSign));
  98:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****         /*
  99:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****          * Decrement the blkCnt loop counter
 100:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****          * Advance vector source and destination pointers
 101:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****          */
 102:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****         pSrc += 4;
 103:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****         pDst += 4;
 104:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****         blkCnt--;
 105:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     }
 106:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** 
 107:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****      /* Tail */
 108:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     blkCnt = (blockSize & 0x3) >> 1;
 109:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** 
 110:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     while (blkCnt > 0U)
 111:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     {
 112:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****       /* C[0] + jC[1] = A[0]+ j(-1)A[1] */
 113:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****   
 114:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****       /* Calculate Complex Conjugate and store result in destination buffer. */
 115:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****       *pDst++ =  *pSrc++;
 116:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****       *pDst++ = -*pSrc++;
 117:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****   
 118:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****       /* Decrement loop counter */
 119:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****       blkCnt--;
 120:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****     }
 121:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** 
 122:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c **** }
