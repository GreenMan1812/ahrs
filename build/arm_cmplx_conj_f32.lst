 143:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****      /* C[0]+jC[1] = A[0]+(-1)*jA[1] */
 144:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****      /* Calculate Complex Conjugate and then store the results in the destination buffer. */
 145:Drivers/CMSIS_DSP/Source/ComplexMathFunctions/arm_cmplx_conj_f32.c ****      vec = vld2q_f32(pSrc);
