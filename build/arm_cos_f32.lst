  71:Drivers/CMSIS_DSP/Source/FastMathFunctions/arm_cos_f32.c ****   @return        cos(x)
  72:Drivers/CMSIS_DSP/Source/FastMathFunctions/arm_cos_f32.c ****  */
  73:Drivers/CMSIS_DSP/Source/FastMathFunctions/arm_cos_f32.c **** ARM_DSP_ATTRIBUTE float32_t arm_cos_f32(
