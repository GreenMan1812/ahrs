 129:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****   blkCnt = blockSize & 3;
 130:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c **** 
 131:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****   while (blkCnt > 0U)
 132:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****   {
 133:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****     /* C = A */
 134:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****     /* Copy and then store the results in the destination buffer */
 135:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****     *pDst++ = *pSrc++;
 136:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c **** 
 137:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****     /* Decrement the loop counter */
 138:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****     blkCnt--;
