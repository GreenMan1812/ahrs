 111:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c **** 
 112:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****   /* Compute 4 outputs at a time.
 113:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****    ** a second loop below computes the remaining 1 to 3 samples. */
 114:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****   while (blkCnt > 0U)
 115:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****   {
 116:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****     /* C = A */
 117:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****     /* Copy and then store the results in the destination buffer */
 118:Drivers/CMSIS_DSP/Source/SupportFunctions/arm_copy_f32.c ****     inV = vld1q_f32(pSrc);
